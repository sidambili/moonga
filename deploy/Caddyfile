# HTTP-only Caddy template for Oncident
# This file is a placeholder: auto_https is off and the site listens on :80 only.
# When a domain is configured, vps-setup.sh overwrites this file with a proper
# HTTPS configuration and enables the caddy service via COMPOSE_PROFILES=https.

{
  auto_https off
}

:80 {
  reverse_proxy api:3000
}
