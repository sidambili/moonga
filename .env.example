# =============================================================================
# Moonga — Environment Variables
# Copy to .env.local for local dev, or .env for Docker / VPS.
# =============================================================================

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# Docker Compose builds DATABASE_URL automatically from this.
# For local dev outside Docker, set DATABASE_URL directly instead:
# DATABASE_URL=postgres://user:pass@localhost:5432/oncident
POSTGRES_PASSWORD=replace-with-a-strong-password

# ---------------------------------------------------------------------------
# Better Auth
# ---------------------------------------------------------------------------

# Generate with: openssl rand -base64 32
# The VPS setup script (deploy/vps-setup.sh) auto-generates this.
BETTER_AUTH_SECRET=replace-with-a-32-char-secret

# Base URL of the API server (where /api/auth/* is served).
# Local dev: http://localhost:5000
# Production: your public domain, e.g. https://your-domain.com
BETTER_AUTH_URL=http://localhost:5000

# Comma-separated frontend origins allowed to make auth requests.
# Needed in local dev when frontend and API run on different ports.
# Leave unset in production (same-origin via Docker).
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:5173

# ---------------------------------------------------------------------------
# Frontend (baked in at build time)
# ---------------------------------------------------------------------------

# Base URL the frontend uses to reach the API.
# Local dev: http://localhost:5000
# Production: leave unset — frontend and API are served from the same origin.
VITE_API_URL=http://localhost:5000

# Controls whether the sign-up page is shown.
# Set both to "false" after creating your first account to close registration.
ALLOW_SIGNUP=true
VITE_ALLOW_SIGNUP=true

# ---------------------------------------------------------------------------
# App runtime
# ---------------------------------------------------------------------------
LOG_LEVEL=info
