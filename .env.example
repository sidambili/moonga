# =============================================================================
# Oncident — Environment Variables
# Copy this file to .env and fill in your secrets.
# .env is loaded automatically by docker-compose.yml.
# =============================================================================

# ---------------------------------------------------------------------------
# Database (used by docker-compose.yml)
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD=replace-with-a-strong-password

# ---------------------------------------------------------------------------
# App runtime (forwarded to the API container)
# ---------------------------------------------------------------------------
LOG_LEVEL=info

# If you run the app outside Docker, set DATABASE_URL directly:
# DATABASE_URL=postgres://user:pass@localhost:5432/oncident

# ---------------------------------------------------------------------------
# Better Auth (authentication)
# ---------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-a-32-char-secret
# Base URL of the API server itself (where /api/auth/* is served).
# In production set this to your public domain, e.g. https://your-domain.com.
BETTER_AUTH_URL=http://localhost:3000
# Comma-separated frontend origins allowed to make auth requests.
# Required in dev when frontend and API run on different ports.
# Leave unset in production (same-origin serving).
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:5173

# Set to "true" to allow new account registration.
# Default is disabled — this app is single-user until you open it up.
ALLOW_SIGNUP=false

# Mirror of ALLOW_SIGNUP for the frontend (baked in at Docker build time).
# This is passed as a build ARG to the Dockerfile; set both to "true" together
# when you want to open registration.
VITE_ALLOW_SIGNUP=false
